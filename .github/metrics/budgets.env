#!/usr/bin/env bash

# Size budgets are intentionally conservative so CI highlights growth before it
# becomes painful for installs or small VPS hosts.
BUDGET_INSTALL_BINARY_MIB=25
BUDGET_RELEASE_TOTAL_MIB=70
BUDGET_TRACKED_REPO_MIB=5
BUDGET_CHECKOUT_DISK_MIB=50
BUDGET_GIT_HISTORY_MIB=20
BUDGET_FIRST_RUN_DISK_MIB=20
BUDGET_IDLE_RSS_MIB=150
BUDGET_STARTUP_MS=5000
BUDGET_TEMPLATE_CATALOG_MIB=1
